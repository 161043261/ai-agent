{
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "scripts": {
    "dev:client": "pnpm --filter @ai-agent/client dev",
    "dev:server": "pnpm --filter @ai-agent/server dev",
    "dev": "concurrently \"pnpm dev:client\" \"pnpm dev:server\"",
    "format:client": "pnpm --filter @ai-agent/client format",
    "format:server": "pnpm --filter @ai-agent/server format",
    "format": "concurrently \"pnpm format:client\" \"pnpm format:server\"",
    "lint:client": "pnpm --filter @ai-agent/client lint",
    "lint:server": "pnpm --filter @ai-agent/server check",
    "lint": "concurrently \"pnpm lint:client\" \"pnpm lint:server\"",
    "build": "concurrently \"pnpm build:client\" \"pnpm build:server\"",
    "build:client": "pnpm --filter @ai-agent/client build",
    "build:server": "pnpm --filter @ai-agent/server build",
    "docker": "echo \"drop database if exists ai_agent; create database ai_agent;\" | docker exec -i mysql mysql -uroot -ppass",
    "ollama": "ollama pull qwen3"
  }
}
