{
  "mcpServers": {
    "amap-maps": {
      "command": "npx.cmd",
      "args": ["-y", "@amap/amap-maps-mcp-server"],
      "env": {
        "AMAP_MAPS_API_KEY": "你的 API Key"
      }
    },
    "yu-image-search-mcp-server": {
      "command": "node",
      "args": ["../mcp-server-js/dist/main.js"],
      "env": {
        "PEXELS_API_KEY": "你的 Pexels API Key"
      }
    }
  }
}
