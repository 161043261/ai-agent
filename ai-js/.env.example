# Server
PORT=8123

# LLM Provider: ollama | dashscope (默认使用 ollama)
LLM_PROVIDER=ollama

# Ollama 本地模型配置 (推荐)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# DashScope 远程模型配置 (阿里云百炼)
# 如果使用 DashScope，设置 LLM_PROVIDER=dashscope
DASHSCOPE_API_KEY=your-api-key
DASHSCOPE_MODEL=qwen-plus

# 网页搜索 API 配置 (SearchAPI.io)
# 用于 searchWeb 工具
SEARCH_API_KEY=your-search-api-key

# MCP 服务配置 (可选)
# 用于连接远程 MCP 服务器 (如图片搜索服务) - StreamableHTTP 协议
MCP_SERVER_URL=http://localhost:8127/mcp

# MCP Stdio 服务配置 (可选)
# 方式1: 使用配置文件 (推荐，与 Java 版本兼容)
# MCP_SERVERS_CONFIG=resources/mcp-servers.json

# 方式2: 用于通过 Stdio 协议连接本地 MCP 服务器
# 格式: JSON 配置，包含 servers 数组
# MCP_STDIO_SERVERS={"servers":[{"name":"image-search","command":"node","args":["../mcp-server-js/dist/index.js"],"env":{"PEXELS_API_KEY":"your-key"}}]}

# RAG 服务配置 (可选)
# 是否启用查询重写
RAG_ENABLE_QUERY_REWRITE=true
# 是否启用多查询扩展
RAG_ENABLE_MULTI_QUERY=false
# 多查询扩展数量
RAG_MULTI_QUERY_COUNT=3
# 是否启用上下文查询增强
RAG_ENABLE_CONTEXTUAL_AUGMENT=true
# 是否启用关键词丰富
RAG_ENABLE_KEYWORD_ENRICH=false
# 文本分割模式: character | token | sentence | paragraph | recursive
RAG_SPLIT_MODE=recursive
# 块大小
RAG_CHUNK_SIZE=500
# 块重叠
RAG_CHUNK_OVERLAP=50
